{
  "id": "gid-lab",
  "realm": "gid-lab",
  "displayName": "GID Lab - Grupo 4",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator role - full access",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Regular user role - limited access",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "sp1-client",
      "name": "Portal A (SP1)",
      "description": "Service Provider 1 - Flask Portal A",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sp1-secret-gid2026",
      "redirectUris": [
        "http://localhost:5001/*"
      ],
      "webOrigins": [
        "http://localhost:5001"
      ],
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "realm roles mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "sp2-client",
      "name": "Portal B (SP2)",
      "description": "Service Provider 2 - Flask Portal B",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sp2-secret-gid2026",
      "redirectUris": [
        "http://localhost:5002/*"
      ],
      "webOrigins": [
        "http://localhost:5002"
      ],
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "realm roles mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
